PORT=8083
NODE_ENV=development

# Security: Minimum 32 characters required for production
ADMIN_API_KEY=your_secure_api_key_here_must_be_long_32chars
JWT_SECRET=your_random_jwt_secret_here_at_least_64_chars
JWT_REFRESH_SECRET=your_random_refresh_token_secret_here_at_least_64_chars
ENCRYPTION_KEY=64_hexadecimal_characters_representing_32_bytes

# Admin Auth (Bcrypt hash required for password)
ADMIN_EMAIL=admin@geosurepath.com
ADMIN_PASSWORD_HASH=$2a$12$ExampleHashReplaceThisWithRealBcryptHash
TRACCAR_ADMIN_EMAIL=admin@example.com

# Database
DATABASE_URL=postgres://postgres:${DB_PASSWORD}@db:5432/traccar
DB_PASSWORD=change_this_to_a_strong_password
BACKUP_DIR=/app/backups

# Redis
REDIS_URL=redis://redis:6379

# Services
TRACCAR_URL=http://traccar:8082
TRACCAR_INTERNAL_URL=http://traccar:8082
TRACCAR_ADMIN_PASSWORD=admin

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM="GeoSurePath" <noreply@geosurepath.com>
SMTP_SECURE=false

# Integrations
RAZORPAY_KEY_ID=rzp_test_your_id
RAZORPAY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Alerts
ALERT_WEBHOOK=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Public URL for Swagger
PUBLIC_URL=http://localhost:8083
