# Master Environment Configuration for GeoSurePath

# Security: Database Password
DB_PASSWORD=your_super_secure_db_password_here

# Security: Admin API Access
ADMIN_API_KEY=your_secure_admin_api_key_here_must_be_32_chars_long
JWT_SECRET=your_random_jwt_secret_here_at_least_64_chars

# Admin Auth Details
ADMIN_EMAIL=admin@geosurepath.com
# Hash for 'admin123'
ADMIN_PASSWORD_HASH=$2a$12$ExampleHashReplaceThisWithRealBcryptHash

# URL for Traccar (for Docker networking)
TRACCAR_URL=http://traccar:8082
# Public URL for Swagger/Frontend
PUBLIC_URL=http://localhost:8083
VITE_ADMIN_API_URL=http://localhost:8083

# Webhook for Alerts
ALERT_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK
