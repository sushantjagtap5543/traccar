# Master Environment Configuration for GeoSurePath

# Security: Database Password
DB_PASSWORD=your_super_secure_db_password_here

# Security: Admin API Access
ADMIN_API_KEY=your_secure_admin_api_key_here_must_be_long_32_chars
JWT_SECRET=your_random_jwt_secret_here_at_least_64_chars
GRAFANA_PASSWORD=your_grafana_admin_password_here
# AES-256 key for encrypting secrets stored in DB (must be exactly 32 chars)
ENCRYPTION_KEY=your_32byte_hex_key_here_replace_now

# Admin Auth Details
ADMIN_EMAIL=admin@geosurepath.com
# Hash for 'admin123'
ADMIN_PASSWORD_HASH=$2a$12$ExampleHashReplaceThisWithRealBcryptHash

# URL for Traccar (for Docker networking)
TRACCAR_URL=http://traccar:8082
TRACCAR_ADMIN_PASSWORD=admin
# Public URL for Swagger/Frontend
PUBLIC_URL=https://localhost
VITE_ADMIN_API_URL=/api/admin

# Bcrypt Password Generation (Run this to get a hash for ADMIN_PASSWORD_HASH)
# node -e "console.log(require('bcryptjs').hashSync('your_password', 12))"

# --- PLATFORM INTEGRATIONS ---
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMBER=
RAZORPAY_KEY_ID=
RAZORPAY_SECRET=

# CORS Configuration
ALLOWED_ORIGINS=https://localhost,http://localhost:3000,http://localhost:5173

# Webhook for Alerts
ALERT_WEBHOOK=https://hooks.slack.com/services/YOUR/WEBHOOK
