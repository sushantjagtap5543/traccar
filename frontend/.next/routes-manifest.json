      "namedRegex": "^/admin/reports(?:/)?$"
    },
    {
      "page": "/admin/users",
      "regex": "^/admin/users(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/users(?:/)?$"
    },
    {
      "page": "/alerts",
      "regex": "^/alerts(?:/)?$",
